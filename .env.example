METRA_API_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TZ=America/Chicago
ROUTE_ID=MD-W
HOME_STOP=YOUR_HOME_STOP_ID   # stop_id resolved at ingest from stops.txt, e.g. ROSELLE
WORK_STOP=CUS                # Chicago Union Station -- the shared downtown terminal for most Metra lines
MORNING_TRAIN=YOUR_TRAIN_NO  # e.g. 2222
EVENING_DEPART_CUS=16:05     # HH:MM departure time from CUS that identifies your evening train
MORNING_BRIEFING=07:15
EVENING_BRIEFING=15:30
QUIET_HOURS=22:00-05:30

# Commute mode (default): only push alerts before COMMUTE_MORNING_END or at/after
# COMMUTE_EVENING_START. Toggle with /commute_mode and /monitor_all in Telegram.
COMMUTE_MORNING_END=09:00
COMMUTE_EVENING_START=15:00

CORS_ORIGIN=https://your-dashboard-domain.example
ALERT_CLEARED_PUSH=false

# Where the SQLite DB and downloaded schedule live (relative to repo root by default)
METRA_DB_PATH=metra.db
